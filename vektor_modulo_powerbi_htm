<style>
  #vektorPowerBiView .vektor-pbi-shell{
    min-height:100vh;
    background:linear-gradient(180deg,#f8fafc 0%,#eef3f8 100%);
  }

  #vektorPowerBiView .vektor-pbi-frame-wrap{
    height:calc(100vh - 220px);
    min-height:640px;
    background:#fff;
    border:3px double #111827;
    border-radius:24px;
    box-shadow:0 24px 60px rgba(15,23,42,.12);
    overflow:hidden;
    position:relative;
  }

  #vektorPowerBiView .vektor-pbi-iframe{
    width:100%;
    height:100%;
    border:0;
    display:none;
    background:#fff;
  }

  #vektorPowerBiView .vektor-pbi-loader{
    position:absolute;
    inset:0;
    display:flex;
    align-items:center;
    justify-content:center;
    flex-direction:column;
    gap:14px;
    background:linear-gradient(180deg,#ffffff 0%,#f8fafc 100%);
  }

  #vektorPowerBiView .vektor-pbi-loader-dot{
    width:46px;
    height:46px;
    border-radius:999px;
    border:4px solid rgba(15,23,42,.10);
    border-top-color:#005E27;
    animation:vektorPbiSpin .8s linear infinite;
  }

  @keyframes vektorPbiSpin{
    to { transform:rotate(360deg); }
  }

  @media (max-width: 980px){
    #vektorPowerBiView .vektor-pbi-frame-wrap{
      min-height:520px;
      height:calc(100vh - 240px);
    }
  }
</style>

<div id="vektorPowerBiView" class="hidden" style="display:none;">
  <div class="vektor-pbi-shell px-8 py-8">
    <div class="mx-auto max-w-[1700px]">

      <div class="rounded-[28px] bg-[linear-gradient(135deg,#061a3a_0%,#0f2d5c_58%,#005E27_100%)] px-8 py-7 text-white shadow-[0_24px_60px_rgba(15,23,42,0.18)]">
        <div class="flex items-start justify-between gap-6 flex-wrap">
          <div class="min-w-0 flex-1">
            <div class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3 py-1 text-[11px] font-extrabold tracking-[0.18em] text-white/85 uppercase">
              Módulo analítico
            </div>

            <h1 class="mt-4 text-4xl font-black tracking-tight">
              Business Intelligence Hub
            </h1>

            <p class="mt-3 text-sm font-semibold leading-6 text-slate-200">
              Relatório Power BI incorporado ao Vektor em uma página dedicada, com abertura via hub principal.
            </p>
          </div>

          <div class="flex items-center gap-3">
            <button
              id="vektorPowerBiBackBtn"
              type="button"
              class="inline-flex items-center gap-2 rounded-2xl border border-white/15 bg-white/10 px-5 py-3 text-sm font-black text-white backdrop-blur-md transition hover:bg-white/15">
              <span>←</span>
              <span>Voltar ao hub</span>
            </button>
          </div>
        </div>
      </div>

      <div class="mt-6 rounded-[24px] border-[3px] border-double border-black bg-white p-5 shadow-[0_20px_45px_rgba(15,23,42,0.08)]">
        <div class="mb-4 flex items-center justify-between gap-4 flex-wrap">
          <div>
            <h2 class="text-lg font-black text-slate-900">Painel incorporado</h2>
            <p class="text-sm font-semibold text-slate-500" id="vektorPowerBiStatus">
              Validando acesso ao módulo e preparando o relatório...
            </p>
          </div>
        </div>

        <div class="vektor-pbi-frame-wrap">
          <div id="vektorPowerBiLoader" class="vektor-pbi-loader">
            <div class="vektor-pbi-loader-dot"></div>
            <div class="text-sm font-extrabold text-slate-700">Carregando relatório Power BI...</div>
            <div class="text-xs font-semibold text-slate-500 text-center px-4">
              A autenticação Microsoft / Power BI pode ser solicitada pelo próprio iframe.
            </div>
          </div>

          <iframe
            id="vektorPowerBiFrame"
            class="vektor-pbi-iframe"
            title="Business Intelligence Hub"
            src=""
            frameborder="0"
            allowfullscreen="true">
          </iframe>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  window.vektorHidePowerBiModule_ = function () {
    var view = document.getElementById("vektorPowerBiView");
    if (!view) return;
    view.classList.add("hidden");
    view.style.display = "none";
  };

  window.vektorShowPowerBiModule_ = function () {
    var hub = document.getElementById("vektorHubView");
    var shell = document.getElementById("vektorShell");
    var topbar = document.getElementById("vektor-topbar");
    var view = document.getElementById("vektorPowerBiView");

    if (hub) {
      hub.classList.add("hidden");
      hub.style.display = "none";
    }

    if (shell) {
      shell.classList.add("hidden");
      shell.style.display = "none";
    }

    if (topbar) {
      topbar.style.display = "none";
    }

    if (view) {
      view.classList.remove("hidden");
      view.style.display = "block";
    }
  };

  window.vektorPowerBiSetStatus_ = function (msg) {
    var el = document.getElementById("vektorPowerBiStatus");
    if (el) el.textContent = String(msg || "");
  };

  window.vektorPowerBiLoad_ = function (force) {
    var frame = document.getElementById("vektorPowerBiFrame");
    var loader = document.getElementById("vektorPowerBiLoader");

    if (!frame || !loader) return;

    if (!force && frame.getAttribute("src")) {
      frame.style.display = "block";
      loader.style.display = "none";
      window.vektorPowerBiSetStatus_("Relatório pronto para uso.");
      return;
    }

    frame.style.display = "none";
    loader.style.display = "flex";
    window.vektorPowerBiSetStatus_("Validando acesso ao módulo e preparando o relatório...");

    google.script.run
      .withSuccessHandler(function (res) {
        if (!res || !res.ok || !res.embedUrl) {
          loader.style.display = "none";
          window.vektorPowerBiSetStatus_("Não foi possível obter a URL do relatório.");
          return;
        }

        frame.onload = function () {
          loader.style.display = "none";
          frame.style.display = "block";
          window.vektorPowerBiSetStatus_("Relatório carregado.");
        };

        frame.src = String(res.embedUrl || "");
      })
      .withFailureHandler(function (err) {
        loader.style.display = "none";
        frame.style.display = "none";

        var msg = (err && err.message)
          ? err.message
          : "Falha ao carregar o relatório Power BI.";

        window.vektorPowerBiSetStatus_(msg);
      })
      .vektorGetPowerBiEmbedData();
  };

</script>
